# Cloud Run Job 環境變數範例，請勿填真實帳密後 commit。
TARGET_URL=https://od.vitalyun.com/
TIMEZONE=Asia/Taipei
DRY_RUN=true
NOTIFY=false
SLOT=
MAX_RECORDS=50
HEADLESS=true

# Apps Script Web App URL。token 建議放 Secret Manager，下面 *_SECRET 可填 secret resource name。
# 未明確設 true 時，即使 APPS_SCRIPT_URL 有值也不會送回 Apps Script。
APPS_SCRIPT_REPORTING_ENABLED=false
APPS_SCRIPT_URL=
APPS_SCRIPT_API_TOKEN_SECRET=
APPS_SCRIPT_ADMIN_TOKEN_SECRET=

# Vital OD 帳密一律放 Secret Manager。
VITAL_OD_USERNAME_SECRET=
VITAL_OD_PASSWORD_SECRET=

# 本機測試可用 mock HTML，不會登入 Vital OD。
MOCK_HTML_PATH=
