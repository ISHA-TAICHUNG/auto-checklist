# 桌面 / 系統暫存
.DS_Store
Thumbs.db
*.swp
.claude_review_state.json
_temp_*

# 原始檢點表 doc / xlsx（敏感資料，不上 GitHub）
*.doc
*.docx
*.xlsx
*.xls

# 本機環境變數
.env
.env.local

# Node / build artifacts（將來如果接 build tool 才會用到）
node_modules/
dist/
build/

# 內部展示 / 對外分享產物（避免誤推到公開 GitHub Pages）
docs/isha-process-flow-overview-internal.html
docs/isha-process-flow-overview-internal-preview.png
docs/presentations/
docs/training-showcase/output/
docs/superpowers/
*.zip

# 測試/實際填表產出的 PDF 不上 git（含具體機構/位置/設備資訊）
*.pdf
.claude/

# clasp 本機設定（含 scriptId，每個開發者各自設定不上 git）
.clasp.json

# clasp 同步的 .js 檔 — 是 live production 版本（Config.js 含真實 token、Setup.js 含機構資訊）
# .gs 才是 git 上的 source of truth（redacted with placeholders）
# 工作流程見 docs/deployment-guide.md 的 clasp 章節
apps-script/*.js
